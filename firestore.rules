rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['deviceId']) &&
             data.deviceId is string && data.deviceId.size() <= 128 && data.deviceId.matches('^[a-zA-Z0-9_\\-]+$') &&
             data.get('email', '') is string &&
             data.get('phone', '') is string &&
             data.get('pin', '') is string &&
             data.get('updatedAt', '') is string;
    }

    match /user_settings/{deviceId} {
      // Allow read (get) if they know the exact deviceId. Block list queries.
      allow get: if true;
      allow list: if false;

      // Allow create if they provide a valid deviceId in the payload that matches the document ID
      allow create: if isValidUserSettings(request.resource.data) &&
                       request.resource.data.deviceId == deviceId;

      // Allow update if they provide a valid payload and the deviceId is not changing
      allow update: if isValidUserSettings(request.resource.data) &&
                       request.resource.data.deviceId == resource.data.deviceId &&
                       request.resource.data.deviceId == deviceId;
      
      allow delete: if false;
    }
  }
}
